{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jhd3197/serverkit-extensions/main/schema/index.schema.json",
  "title": "ServerKit extension registry index",
  "type": "object",
  "required": ["schema_version", "updated", "extensions"],
  "properties": {
    "schema_version": { "const": 1 },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date of the last index change (YYYY-MM-DD)."
    },
    "extensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/extension" }
    }
  },
  "$defs": {
    "semverish": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?([.-][0-9A-Za-z.-]+)?$"
    },
    "extension": {
      "type": "object",
      "required": ["slug", "display_name", "version", "source"],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Kebab-case, must match the manifest's name."
        },
        "display_name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "version": { "$ref": "#/$defs/semverish" },
        "category": {
          "enum": ["ai", "monitoring", "security", "deployment", "integration", "ui", "utility"]
        },
        "author": { "type": "string" },
        "first_party": {
          "type": "boolean",
          "description": "true only for ServerKit-authored entries."
        },
        "permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "min_panel_version": {
          "anyOf": [{ "$ref": "#/$defs/semverish" }, { "type": "null" }]
        },
        "max_panel_version": {
          "anyOf": [{ "$ref": "#/$defs/semverish" }, { "type": "null" }]
        },
        "source": {
          "type": "string",
          "pattern": "^https://",
          "description": "Repo URL (latest release), release-tag URL, or direct .zip URL."
        },
        "sha256": {
          "anyOf": [
            { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            { "type": "null" }
          ],
          "description": "sha256 of the exact zip `source` resolves to. Enforced when present."
        },
        "homepage": {
          "anyOf": [{ "type": "string", "pattern": "^https?://" }, { "type": "null" }]
        },
        "icon": {
          "type": "string",
          "description": "Inner SVG markup (24x24 viewBox assumed by the panel)."
        },
        "screenshots": {
          "type": "array",
          "items": { "type": "string", "pattern": "^https://" }
        }
      }
    }
  }
}
